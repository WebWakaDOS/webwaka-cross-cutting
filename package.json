{
  "name": "webwaka-cross-cutting",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --alias dexie:./src/stubs/dexie.js --ip 0.0.0.0 --port 5000",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@webwaka/core": "^1.6.1",
    "dexie": "^4.4.2",
    "hono": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "undici": ">=6.24.0",
    "esbuild": ">=0.25.0"
  }
}
